import "events.net";
import "stdio.net";

event DoneEvent {};

actor Main() : * -> mainRet: RetCode; start = sender {
  Sender  sender()  with { receiver = doubler, doneSending = doubler, stdOut = stdOut };
  Doubler doubler() with { receiver = checker, stdOut = stdOut, doneSending = checker };
  Checker checker() with { receiver = mainRet, stdOut = stdOut };
  StdOut stdOut() with {};
}


actor Doubler() : Integer | DoneEvent -> 
  receiver: Integer, stdOut: String, doneSending: DoneEvent {
        
    control { }
    init { }

    handler Integer (e) {
      trigger String with { value = ("Doubler received Integer event with value " ++ toString(e.value) ++ "\n") } for stdOut;
      e.value = e.value * 2;
      trigger String with { value = ("\tDoubler sending Integer event with value " ++ toString(e.value) ++ "\n") } for stdOut;
      trigger e for receiver;
    }

    handler DoneEvent (e) {
      trigger String with { value = ("Doubler received DoneEvent\n") } for stdOut;
      trigger e for doneSending;
      trigger String with { value = ("\tDoubler sending DoneEvent\n") } for stdOut;
    }

}


actor Sender() : Integer -> receiver: Integer, doneSending: DoneEvent, stdOut: String {

  control { }

  init {

    trigger String with { value = ("===================================\n") } for stdOut;
    trigger String with { value = ("===== Double program starting =====\n") } for stdOut;

    Integer first  = Integer with { value = 2 };
    Integer second = Integer with { value = 2 };
    Integer third  = Integer with { value = 2 };

    trigger first  for receiver;
    trigger second for receiver;
    trigger third  for receiver;

    DoneEvent done = DoneEvent with {};
    trigger done for doneSending;

  }

  handler Integer(e) {}

}


actor Checker() : Integer | DoneEvent -> receiver: RetCode, stdOut: String {

  control { bool passed = true; }
  init { passed = true; }

  handler Integer (e) {  // or all as handlers
    trigger String with { value = ("Checker received Integer e with value " ++ toString(e.value) ++ "\n") } for stdOut;
    if (e.value % 2 != 0) {
      trigger String with { value = ("\tValue was not even, failed\n") } for stdOut;
      updatePassed(false);
    } else {
      trigger String with { value = ("\tValue was even, passed\n") } for stdOut;
    }
  }

  handler DoneEvent (e) {
    trigger String with { value = ("Checker received DoneEvent\n") } for stdOut;
    int resCode;
    if (passed) {
      trigger String with { value = ("\tAll tests passed\n") } for stdOut;
      resCode = 0;
    }
    else {
      trigger String with { value = ("\tTesting failed\n") } for stdOut;
      resCode = -1;
    }
    RetCode ret = RetCode with { code = resCode };
    trigger ret for receiver;
    trigger String with { value = ("===== Double program complete =====\n") } for stdOut;
    trigger String with { value = ("===================================\n") } for stdOut;
  }

  action updatePassed (bool result) {
    trigger String with { value = ("\tUpdating passed...\n") } for stdOut;
    passed = passed && result;
  }

}